{
  "protection_levels": {
    "no_access": {
      "description": "Blocked from all access (Read, Edit, Write, Bash)",
      "patterns": [
        ".env", ".env.*",
        ".ssh/*",
        ".aws/credentials", ".aws/config",
        "credentials.json", "credentials.yaml",
        "*.pem", "*.key",
        ".kube/config",
        "secrets.yml", "secrets.yaml"
      ]
    },
    "read_only": {
      "description": "Read allowed, Edit/Write blocked",
      "patterns": [
        "package-lock.json", "yarn.lock",
        "pnpm-lock.yaml", "Cargo.lock",
        "poetry.lock", "go.sum"
      ]
    },
    "no_delete": {
      "description": "Read/Edit allowed, deletion (rm) blocked",
      "patterns": [
        ".git/*", "LICENSE", "README.md"
      ]
    }
  }
}
