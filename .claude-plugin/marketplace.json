{
  "name": "coding-agent-toolkit",
  "owner": {
    "name": "Tobias"
  },
  "metadata": {
    "description": "Common development workflows and tools for Claude Code",
    "pluginRoot": "./plugins"
  },
  "plugins": [
    {
      "name": "cc-workflows",
      "source": "./plugins/cc-workflows",
      "strict": false,
      "version": "0.9.2",
      "description": "Claude Code workflows: requirements clarification, spec generation/execution, code review, trade-off analysis, and design tools",
      "author": {
        "name": "Tobias"
      },
      "license": "MIT",
      "keywords": [
        "workflow",
        "specification",
        "code-review",
        "implementation",
        "requirements",
        "trade-off-analysis",
        "wireframes",
        "design-system"
      ]
    },
    {
      "name": "dart-lsp",
      "source": "./plugins/dart-lsp",
      "strict": false,
      "version": "1.0.0",
      "description": "Dart language server for code intelligence in Dart/Flutter projects",
      "author": {
        "name": "Tobias"
      },
      "category": "development",
      "lspServers": {
        "dart": {
          "command": "dart",
          "args": ["language-server"],
          "extensionToLanguage": {
            ".dart": "dart"
          }
        }
      }
    }
  ]
}
